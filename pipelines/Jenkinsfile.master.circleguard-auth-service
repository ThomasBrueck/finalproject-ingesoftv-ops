pipeline {
    agent any

    parameters {
        string(name: 'DEV_REPO_BRANCH',
               defaultValue: 'master',
               description: 'Branch o commit SHA del repo de desarrollo a construir')
    }

    environment {
        SERVICE_NAME  = "circleguard-auth-service"
        IMAGE_NAME    = "circle-guard/circleguard-auth-service"
        IMAGE_TAG     = "${env.BUILD_NUMBER}"
        K8S_NS        = "production"
        JWT_SECRET_VAL = "my-super-secret-prod-key-32-chars-long-12345"
        QR_SECRET_VAL  = "my-qr-secret-key-for-prod-1234567890"
        DB_USER_VAL    = "admin"
        DB_PASS_VAL    = "password"
        LDAP_USER_VAL  = "cn=admin,dc=circleguard,dc=edu"
        LDAP_PASS_VAL  = "admin"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                dir('app') {
                    git url: 'https://github.com/ThomasBrueck/circle-guard-public-dev',
                        branch: "${params.DEV_REPO_BRANCH}"
                }
                script {
                    env.DEV_COMMIT = sh(script: 'git -C app rev-parse --short HEAD', returnStdout: true).trim()
                    echo "DEV repo commit: ${env.DEV_COMMIT} | INFRA build: ${IMAGE_TAG}"
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                sh """
                    docker build \\
                        -f services/${SERVICE_NAME}/Dockerfile \\
                        -t ${IMAGE_NAME}:${IMAGE_TAG} \\
                        --label "dev-commit=${env.DEV_COMMIT}" \\
                        --label "build-number=${IMAGE_TAG}" \\
                        app/
                    if minikube image ls 2>/dev/null | grep -qF "${IMAGE_NAME}:${env.DEV_COMMIT}"; then
                        echo "Imagen ${env.DEV_COMMIT} ya en minikube, omitiendo carga"
                    else
                        docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:${env.DEV_COMMIT}
                        minikube image load ${IMAGE_NAME}:${env.DEV_COMMIT}
                    fi
                """
            }
        }

        stage('Unit Tests') {
            steps {
                catchError(buildResult: 'SUCCESS', stageResult: 'UNSTABLE') {
                    sh """
                        docker build --target builder \\
                            -f services/${SERVICE_NAME}/Dockerfile \\
                            -t ${IMAGE_NAME}:builder-${IMAGE_TAG} \\
                            app/
                        docker volume create gradle-cache-${IMAGE_TAG} || true
                        docker rm -f test-runner-${IMAGE_TAG} 2>/dev/null || true
                        docker run --name test-runner-${IMAGE_TAG} \\
                            -e SPRING_MAIN_LAZY_INITIALIZATION=true \\
                            -e SPRING_DATASOURCE_HIKARI_INITIALIZATION_FAIL_TIMEOUT=0 \\
                            -e MANAGEMENT_HEALTH_DATASOURCE_ENABLED=false \\
                            -e MANAGEMENT_HEALTH_LDAP_ENABLED=false \\
                            -e MANAGEMENT_HEALTH_KAFKA_ENABLED=false \\
                            -e SPRING_KAFKA_LISTENER_MISSING_TOPICS_FATAL=false \\
                            -v gradle-cache-${IMAGE_TAG}:/root/.gradle \\
                            ${IMAGE_NAME}:builder-${IMAGE_TAG} \\
                            ./gradlew :services:${SERVICE_NAME}:test \\
                                --tests 'com.circleguard.*.service.*' \\
                                --tests 'com.circleguard.*.controller.*' \\
                                --no-daemon; TEST_EXIT=\$?
                        rm -rf test-results && mkdir -p test-results
                        docker cp test-runner-${IMAGE_TAG}:/app/services/${SERVICE_NAME}/build/test-results/test/. test-results/ || true
                        docker rm test-runner-${IMAGE_TAG} || true
                        exit \$TEST_EXIT
                    """
                }
            }
            post {
                always { junit allowEmptyResults: true, testResults: 'test-results/**/*.xml' }
            }
        }

        stage('System Tests') {
            steps {
                sh """
                    docker rm -f system-test-${IMAGE_TAG} 2>/dev/null || true
                    docker run --name system-test-${IMAGE_TAG} \\
                        -e SPRING_MAIN_LAZY_INITIALIZATION=true \\
                        -e SPRING_DATASOURCE_HIKARI_INITIALIZATION_FAIL_TIMEOUT=0 \\
                        -e MANAGEMENT_HEALTH_DATASOURCE_ENABLED=false \\
                        -e MANAGEMENT_HEALTH_LDAP_ENABLED=false \\
                        -e MANAGEMENT_HEALTH_KAFKA_ENABLED=false \\
                        -e SPRING_KAFKA_LISTENER_MISSING_TOPICS_FATAL=false \\
                        -v gradle-cache-${IMAGE_TAG}:/root/.gradle \\
                        ${IMAGE_NAME}:builder-${IMAGE_TAG} \\
                        ./gradlew :services:${SERVICE_NAME}:test --no-daemon; SYS_EXIT=\$?
                    rm -rf system-test-results && mkdir -p system-test-results
                    docker cp system-test-${IMAGE_TAG}:/app/services/${SERVICE_NAME}/build/test-results/test/. system-test-results/ || true
                    docker rm system-test-${IMAGE_TAG} || true
                    exit \$SYS_EXIT
                """
            }
            post {
                always { junit allowEmptyResults: true, testResults: 'system-test-results/**/*.xml' }
            }
        }

        stage('Approval Gate') {
            steps {
                timeout(time: 30, unit: 'MINUTES') {
                    input message: "Aprobar despliegue de ${SERVICE_NAME} v${IMAGE_TAG} a PRODUCCION?",
                          ok: 'Aprobar y Desplegar'
                }
            }
        }

        stage('Deploy to Production K8s') {
            steps {
                sh "kubectl delete pods -n ${K8S_NS} -l app=${SERVICE_NAME} --force --grace-period=0 2>/dev/null || true"
                sh "kubectl apply -f k8s/production/00-namespace.yaml"
                sh """
                    kubectl create secret generic circleguard-production-secrets \\
                        --from-literal=JWT_SECRET="${env.JWT_SECRET_VAL}" \\
                        --from-literal=QR_SECRET="${env.QR_SECRET_VAL}" \\
                        --from-literal=DB_USERNAME="${env.DB_USER_VAL}" \\
                        --from-literal=DB_PASSWORD="${env.DB_PASS_VAL}" \\
                        --from-literal=LDAP_USERNAME="${env.LDAP_USER_VAL}" \\
                        --from-literal=LDAP_PASSWORD="${env.LDAP_PASS_VAL}" \\
                        -n ${K8S_NS} --dry-run=client -o yaml | kubectl apply -f -
                """
                sh "kubectl delete deployment/${SERVICE_NAME} -n ${K8S_NS} --ignore-not-found=true 2>/dev/null || true"
                sh "kubectl apply -f k8s/production/${SERVICE_NAME}-deployment.yaml"
                sh "kubectl set image deployment/${SERVICE_NAME} ${SERVICE_NAME}=${IMAGE_NAME}:${env.DEV_COMMIT} -n ${K8S_NS}"
                sh "kubectl rollout status deployment/${SERVICE_NAME} -n ${K8S_NS} --timeout=600s"
            }
        }

        stage('Smoke Test on Production') {
            steps {
                sh """
                    MINIKUBE_IP=\$(minikube ip)
                    NODE_PORT=\$(kubectl get svc ${SERVICE_NAME} -n ${K8S_NS} -o jsonpath='{.spec.ports[0].nodePort}')
                    PROD_URL="http://\${MINIKUBE_IP}:\${NODE_PORT}"
                    echo "Smoke test en PRODUCCION: \${PROD_URL}"
                    for i in 1 2 3; do
                        STATUS=\$(curl -s -o /dev/null -w "%{http_code}" "\${PROD_URL}/actuator/health" || echo "000")
                        if [ "\$STATUS" != "000" ] && echo "\$STATUS" | grep -qvE "^5"; then
                            echo "Smoke test OK: HTTP \$STATUS"; exit 0
                        fi
                        echo "Intento \$i: status=\${STATUS}, reintentando en 5s..."; sleep 5
                    done
                    echo "FALLO: servicio no saludable en produccion tras 3 intentos"; exit 1
                """
            }
        }

        stage('Generate Release Notes') {
            steps {
                script {
                    env.RELEASE_TAG = "release/${SERVICE_NAME}/v${IMAGE_TAG}"
                }
                sh 'chmod +x scripts/generate-release-notes.sh && ./scripts/generate-release-notes.sh'
                sh """
                    git tag -a "${env.RELEASE_TAG}" \\
                        -m "Production release ${SERVICE_NAME} v${IMAGE_TAG}" || true
                    git push origin "${env.RELEASE_TAG}" || true
                    if command -v gh >/dev/null 2>&1; then
                        gh release create "${env.RELEASE_TAG}" \\
                            --title "${SERVICE_NAME} v${IMAGE_TAG}" \\
                            --notes-file release-notes.md \\
                            --repo ThomasBrueck/circle-guard-public || true
                    else
                        echo "gh CLI no disponible - Release Notes guardadas como artefacto Jenkins"
                    fi
                """
                archiveArtifacts artifacts: 'release-notes.md', allowEmptyArchive: true
            }
        }
    }

    post {
        always {
            sh "docker rmi ${IMAGE_NAME}:builder-${IMAGE_TAG} || true"
            sh "docker volume rm gradle-cache-${IMAGE_TAG} || true"
        }
        failure {
            script {
                echo "Pipeline FALLO — rollback de ${SERVICE_NAME} en ${K8S_NS}"
                sh "kubectl rollout undo deployment/${SERVICE_NAME} -n ${K8S_NS} || true"
                sh "kubectl rollout status deployment/${SERVICE_NAME} -n ${K8S_NS} --timeout=120s || true"
            }
        }
        success {
            echo "Produccion OK: ${SERVICE_NAME}:${IMAGE_TAG} (dev commit: ${env.DEV_COMMIT})"
        }
    }
}
