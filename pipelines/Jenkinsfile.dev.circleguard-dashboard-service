pipeline {
    agent any
    environment {
        SERVICE_NAME = "circleguard-dashboard-service"
        IMAGE_NAME   = "circle-guard/circleguard-dashboard-service"
        IMAGE_TAG    = "${env.BUILD_NUMBER}"
        K8S_NS       = "dev"
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
                dir('app') {
                    git url: 'https://github.com/ThomasBrueck/circle-guard-public-dev', branch: 'master'
                }
            }
        }
        stage('Build Docker Image') {
            steps {
                sh """
                    docker build \\
                        -f app/services/${SERVICE_NAME}/Dockerfile \\
                        -t ${IMAGE_NAME}:${IMAGE_TAG} \\
                        app/
                    docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest
                    minikube image load ${IMAGE_NAME}:${IMAGE_TAG}
                    minikube image load ${IMAGE_NAME}:latest
                """
            }
        }
        stage('Unit Tests') {
            steps {
                sh """
                    docker build --target builder \\
                        -f app/services/${SERVICE_NAME}/Dockerfile \\
                        -t ${IMAGE_NAME}:builder-${IMAGE_TAG} \\
                        app/
                    docker rm -f test-runner-${IMAGE_TAG} 2>/dev/null || true
                    docker run --name test-runner-${IMAGE_TAG} \\
                        ${IMAGE_NAME}:builder-${IMAGE_TAG} \\
                        ./gradlew :services:${SERVICE_NAME}:test --tests 'com.circleguard.*.service.*' --tests 'com.circleguard.*.controller.*' --no-daemon; TEST_EXIT=\$?
                    rm -rf test-results && mkdir -p test-results
                    docker cp test-runner-${IMAGE_TAG}:/app/services/${SERVICE_NAME}/build/test-results/test/. test-results/ || true
                    docker rm test-runner-${IMAGE_TAG} || true
                    exit \$TEST_EXIT
                """
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'test-results/**/*.xml'
                }
            }
        }
        stage('Integration Tests') {
            steps {
                sh """
                    INT_COUNT=\$(find app/services/${SERVICE_NAME}/src/test -name "*IntegrationTest.java" 2>/dev/null | wc -l)
                    if [ "\$INT_COUNT" -eq 0 ]; then
                        echo "No integration tests found for ${SERVICE_NAME}, skipping"
                        exit 0
                    fi
                    docker rm -f int-runner-${IMAGE_TAG} 2>/dev/null || true
                    docker run --name int-runner-${IMAGE_TAG} \\
                        ${IMAGE_NAME}:builder-${IMAGE_TAG} \\
                        ./gradlew :services:${SERVICE_NAME}:test --tests 'com.circleguard.*.integration.*' --no-daemon; INT_EXIT=\$?
                    rm -rf integration-results && mkdir -p integration-results
                    docker cp int-runner-${IMAGE_TAG}:/app/services/${SERVICE_NAME}/build/test-results/test/. integration-results/ || true
                    docker rm int-runner-${IMAGE_TAG} || true
                    exit \$INT_EXIT
                """
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'integration-results/**/*.xml'
                }
            }
        }
        stage('E2E Tests') {
            steps {
                sh """
                    E2E_COUNT=\$(find app/services/${SERVICE_NAME}/src/test -name "*E2ETest.java" 2>/dev/null | wc -l)
                    if [ "\$E2E_COUNT" -eq 0 ]; then
                        echo "No E2E tests found for ${SERVICE_NAME}, skipping"
                        exit 0
                    fi
                    docker rm -f e2e-runner-${IMAGE_TAG} 2>/dev/null || true
                    docker run --name e2e-runner-${IMAGE_TAG} \\
                        ${IMAGE_NAME}:builder-${IMAGE_TAG} \\
                        ./gradlew :services:${SERVICE_NAME}:test --tests 'com.circleguard.*.e2e.*' --no-daemon; E2E_EXIT=\$?
                    rm -rf e2e-results && mkdir -p e2e-results
                    docker cp e2e-runner-${IMAGE_TAG}:/app/services/${SERVICE_NAME}/build/test-results/test/. e2e-results/ || true
                    docker rm e2e-runner-${IMAGE_TAG} || true
                    exit \$E2E_EXIT
                """
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: 'e2e-results/**/*.xml'
                }
            }
        }
        stage('Deploy to Dev K8s') {
            steps {
                sh "kubectl create namespace ${K8S_NS} --dry-run=client -o yaml | kubectl apply -f -"
                sh "kubectl apply -f k8s/dev/${SERVICE_NAME}-deployment.yaml -n ${K8S_NS}"
                sh "kubectl set image deployment/${SERVICE_NAME} ${SERVICE_NAME}=${IMAGE_NAME}:${IMAGE_TAG} -n ${K8S_NS}"
                sh "kubectl rollout status deployment/${SERVICE_NAME} -n ${K8S_NS} --timeout=300s"
            }
        }
        stage('Performance Tests') {
            steps {
                sh """
                    SVC_PORT=\$(kubectl get svc ${SERVICE_NAME} -n ${K8S_NS} -o jsonpath='{.spec.ports[0].nodePort}' 2>/dev/null || echo '8080')
                    MINIKUBE_IP=\$(minikube ip 2>/dev/null || echo 'localhost')
                    docker run --rm --network host \\
                        -v \$(pwd)/tests/performance/locust:/mnt/locust \\
                        locustio/locust \\
                        -f /mnt/locust/locustfile.py \\
                        --headless --users 10 --spawn-rate 2 --run-time 30s \\
                        --host http://\${MINIKUBE_IP}:\${SVC_PORT} \\
                        --only-summary || true
                """
            }
        }
    }
    post {
        failure { echo "Pipeline FALLÓ para ${SERVICE_NAME}" }
        success { echo "Pipeline DEV completado para ${SERVICE_NAME}:${IMAGE_TAG}" }
    }
}
